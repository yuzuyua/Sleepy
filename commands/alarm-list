import { SlashCommandBuilder } from "discord.js";
export const data = new SlashCommandBuilder()
  .setName("alarm-list")
  .set description("設定中のアラームを一覧表示します");

export const devOnly =true;

const alarms = loadAlarms().filter(a => a.guildId === interaction.guildId);
 
if (alarms.length === 0) {
  return interaction.reply("アラームはありません");
}

const text = alarms.map(a =>
  `ID:${a.id} <t:${Math.floor(a.executeAt/1000)}:t>`
).join("\n");

await interaction.reply("設定中アラーム一覧"\n text);
